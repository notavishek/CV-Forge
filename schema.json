{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CVData",
  "type": "object",
  "required": ["personal", "education", "experience", "skills", "projects"],
  "properties": {
    "personal": {
      "type": "object",
      "required": ["name", "title", "email", "phone", "location"],
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "website": { "type": "string" },
        "linkedin": { "type": "string" },
        "github": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["school", "degree", "location", "start", "end"],
        "properties": {
          "school": { "type": "string" },
          "degree": { "type": "string" },
          "location": { "type": "string" },
          "start": { "type": "string" },
          "end": { "type": "string" },
          "details": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["company", "role", "location", "start", "end"],
        "properties": {
          "company": { "type": "string" },
          "role": { "type": "string" },
          "location": { "type": "string" },
          "start": { "type": "string" },
          "end": { "type": "string" },
          "highlights": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "skills": {
      "type": "object",
      "required": ["languages", "frameworks", "tools"],
      "properties": {
        "languages": { "type": "array", "items": { "type": "string" } },
        "frameworks": { "type": "array", "items": { "type": "string" } },
        "tools": { "type": "array", "items": { "type": "string" } }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "tech": { "type": "array", "items": { "type": "string" } },
          "link": { "type": "string" }
        }
      }
    }
  }
}
